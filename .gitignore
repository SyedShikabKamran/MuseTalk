# =========================
# Python environments
# =========================
musetalk_env/
venv/
env/
.env

# =========================
# Model weights (ignore actual weights, keep folder structure)
# =========================
models/musetalk/*.bin
models/musetalk/*.safetensors

models/musetalkV15/*.pth
models/musetalkV15/*.safetensors

models/whisper/*.bin
models/whisper/*.safetensors

models/dwpose/*.pth
models/dwpose/*.safetensors

models/syncnet/*.pt
models/syncnet/*.safetensors

models/sd-vae/*.bin
models/sd-vae/*.safetensors

models/face-parse-bisent/*.pth
models/face-parse-bisent/*.safetensors

# optional extra model types
models/**/*.ckpt
models/**/*.pt
models/**/*.pth
models/**/*.bin
models/**/*.safetensors

# keep placeholder file if needed
!models/.gitkeep

# =========================
# Python caches and build files
# =========================
**/__pycache__/
__pycache__/
*.pyc
*.pyo
*.pyd
*.py[cod]
*$py.class
*.egg-info/
dist/
build/

# =========================
# IDE / editor files
# =========================
.vscode/
.idea/
*.swp
*.swo
*~

# =========================
# OS / system files
# =========================
.DS_Store
Thumbs.db

